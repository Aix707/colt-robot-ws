# udev rule for wpv4
#
#KERNEL=="ttyUSB*", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", MODE:="0777", SYMLINK+="ftdi"
#udevadm info -a /dev/ttyUSB0 |  grep 'KERNELS'
KERNEL=="ttyACM*", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="55d4", MODE:="0777", SYMLINK+="fdilink_ahrs"
KERNEL=="ttyUSB*", KERNELS=="3-1.2.1.1", MODE:="0777", SYMLINK+="wpv4_base"
KERNEL=="ttyUSB*", KERNELS=="3-1.1", MODE:="0777", SYMLINK+="wpv4_mani"
KERNEL=="ttyUSB*", KERNELS=="3-1.4", MODE:="0777", SYMLINK+="wpv4_pt"
KERNEL=="ttyUSB*", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", MODE:="0777", SYMLINK+="ublox_gps"
