<launch>
  <arg name="output_root" default="$(env HOME)/colt_capture_sessions"/>
  <arg name="capture_rate_hz" default="2.0"/>
  <arg name="auto_start" default="false"/>
  <arg name="max_frames" default="0"/>

  <arg name="color_topic" default="/kinect2/qhd/image_color_rect"/>
  <arg name="depth_topic" default="/kinect2/qhd/image_depth_rect"/>
  <arg name="points_topic" default="/kinect2/qhd/points"/>
  <arg name="camera_info_topic" default="/kinect2/qhd/camera_info"/>

  <node pkg="colt_bridle" type="colt_capture_session.py" name="colt_capture_session" output="screen">
    <param name="output_root" value="$(arg output_root)"/>
    <param name="capture_rate_hz" value="$(arg capture_rate_hz)"/>
    <param name="auto_start" value="$(arg auto_start)"/>
    <param name="max_frames" value="$(arg max_frames)"/>
    <param name="color_topic" value="$(arg color_topic)"/>
    <param name="depth_topic" value="$(arg depth_topic)"/>
    <param name="points_topic" value="$(arg points_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
  </node>
</launch>
